			"@astrojs/react": "^5.0.7",
			"@aws-sdk/client-s3": "^3.1063.0",
			"@aws-sdk/s3-request-presigner": "^3.1063.0",
			"@better-auth/api-key": "^1.6.14",
			"@cloudflare/workers-types": "^4.20260607.1",
			"@dagrejs/dagre": "^3.0.0",
			"@dnd-kit/core": "^6.3.1",
			"@dnd-kit/sortable": "^10.0.0",
