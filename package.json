{
	"name": "relayapi",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*",
			"packages/integrations/*"
		],
		"catalog": {
			"@astrojs/cloudflare": "^13.1.0",
			"@astrojs/react": "^5.0.0",
			"@aws-sdk/client-s3": "^3.1019.0",
			"@aws-sdk/s3-request-presigner": "^3.1019.0",
			"@better-auth/api-key": "^1.5.5",
			"@cloudflare/workers-types": "^4.20250312.0",
			"@dnd-kit/core": "^6.3.1",
			"@dnd-kit/sortable": "^10.0.0",
			"@dnd-kit/utilities": "^3.2.2",
			"@fontsource-variable/geist": "^5.2.8",
			"@fontsource-variable/geist-mono": "^5.2.7",
			"@hono/swagger-ui": "^0.6.1",
			"@hono/zod-openapi": "^1.2.2",
			"@opennextjs/cloudflare": "^1.0.0",
			"@radix-ui/react-accordion": "^1.2.12",
			"@radix-ui/react-navigation-menu": "^1.2.14",
			"@radix-ui/react-popover": "^1.1.15",
			"@radix-ui/react-select": "^2.2.6",
			"@radix-ui/react-slot": "^1.2.3",
			"@react-email/components": "^1.0.10",
			"@react-email/render": "^2.0.4",
			"@react-three/fiber": "^9.5.0",
			"@react-three/postprocessing": "^3.0.4",
			"@tailwindcss/postcss": "^4.2.1",
			"@tailwindcss/vite": "^4.2.1",
			"@tanstack/react-table": "^8.21.3",
			"@tsparticles/engine": "^3.9.1",
			"@tsparticles/react": "^3.0.0",
			"@tsparticles/slim": "^3.9.1",
			"@types/mdx": "^2.0.13",
			"@types/node": "^25.5.0",
			"@types/react": "^19",
			"@types/react-dom": "^19",
			"@types/three": "^0.183.1",
			"astro": "^6.0.3",
			"better-auth": "^1.5.5",
			"class-variance-authority": "^0.7.1",
			"clsx": "^2.1.1",
			"date-fns": "^4.1.0",
			"dotenv-cli": "^11.0.0",
			"drizzle-kit": "^0.31.9",
			"drizzle-orm": "^0.45.1",
			"fast-xml-parser": "^5.5.10",
			"fumadocs-core": "^16.6.16",
			"fumadocs-mdx": "^14.2.9",
			"fumadocs-openapi": "^10.3.18",
			"fumadocs-ui": "^16.6.16",
			"hono": "^4.12.7",
			"json-schema-typed": "^8.0.2",
			"lucide-react": "^0.552.0",
			"motion": "^12.36.0",
			"next": "~16.1.6",
			"postgres": "^3.4.8",
			"postprocessing": "^6.38.3",
			"radix-ui": "^1.4.3",
			"react": "^19",
			"react-dom": "^19",
			"reactflow": "^11.11.4",
			"resend": "^6.10.0",
			"shiki": "^3.7.0",
			"simple-icons": "^16.13.0",
			"stripe": "^20.4.1",
			"svg-dotted-map": "^2.0.1",
			"tailwind-merge": "^3.5.0",
			"tailwindcss": "^4.2.1",
			"three": "^0.183.2",
			"tw-animate-css": "^1.4.0",
			"typescript": "^5.8",
			"wrangler": "^4.72.0",
			"zod": "^4.3.6"
		}
	},
	"scripts": {
		"dev:api": "cd apps/api && bun run dev",
		"dev:app": "cd apps/app && bun run dev",
		"dev:docs": "cd apps/docs && bun run dev",
		"dev:cli": "cd apps/cli && bun run dev",
		"typecheck": "bun run typecheck:db && bun run typecheck:auth && bun run build:sdk && bun run typecheck:api && bun run typecheck:app && bun run typecheck:docs && bun run typecheck:cli && bun run typecheck:n8n && bun run typecheck:zapier",
		"typecheck:db": "cd packages/db && tsc --noEmit",
		"typecheck:auth": "cd packages/auth && tsc --noEmit",
		"build:sdk": "cd packages/sdk && tsc -p tsconfig.build.json",
		"typecheck:api": "cd apps/api && tsc --noEmit",
		"typecheck:app": "cd apps/app && tsc --noEmit",
		"typecheck:docs": "cd apps/docs && tsc --noEmit",
		"typecheck:cli": "cd apps/cli && tsc --noEmit",
		"typecheck:n8n": "cd packages/integrations/n8n-node && tsc --noEmit",
		"typecheck:zapier": "cd packages/integrations/zapier-app && tsc --noEmit",
		"db:generate": "cd packages/db && bunx drizzle-kit generate",
		"db:studio": "cd packages/db && bunx drizzle-kit studio",
		"db:migrate": "cd packages/db && bunx drizzle-kit migrate",
		"deps:upgrade": "bun run scripts/upgrade-catalog.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.12"
	},
	"patchedDependencies": {
		"undici@7.24.4": "patches/undici@7.24.4.patch"
	}
}
