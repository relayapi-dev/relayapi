{
	"name": "@relayapi/api",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "dotenv -e .dev.vars -- wrangler dev --port 8789 --persist-to ../../.wrangler/state",
		"build": "cd ../.. && bun install && cd apps/api",
		"deploy": "wrangler deploy",
		"test": "bun test",
		"test:billing": "for f in src/__tests__/auth.test.ts src/__tests__/stripe-webhooks.test.ts src/__tests__/usage-tracking.test.ts src/__tests__/billing-flows.test.ts; do bun test ./$f || exit 1; done"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "catalog:",
		"@aws-sdk/s3-request-presigner": "catalog:",
		"@dagrejs/dagre": "catalog:",
		"@hono/swagger-ui": "catalog:",
		"@hono/zod-openapi": "catalog:",
		"@react-email/components": "catalog:",
		"@react-email/render": "catalog:",
		"@relayapi/db": "workspace:*",
		"fast-xml-parser": "catalog:",
		"hono": "catalog:",
		"resend": "catalog:",
		"stripe": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "catalog:",
		"dotenv-cli": "catalog:",
		"typescript": "catalog:",
		"wrangler": "catalog:"
	}
}
