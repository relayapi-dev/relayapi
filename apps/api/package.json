{
	"name": "@relayapi/api",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "wrangler dev --port 8789 --persist-to ../../.wrangler/state",
		"build": "cd ../.. && bun install && cd apps/api",
		"deploy": "wrangler deploy",
		"test": "bun test",
		"test:billing": "for f in src/__tests__/auth.test.ts src/__tests__/stripe-webhooks.test.ts src/__tests__/usage-tracking.test.ts src/__tests__/billing-flows.test.ts; do bun test ./$f || exit 1; done"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1019.0",
		"@aws-sdk/s3-request-presigner": "^3.1019.0",
		"@hono/swagger-ui": "^0.6.1",
		"@hono/zod-openapi": "^1.2.2",
		"@react-email/components": "^1.0.10",
		"@react-email/render": "^2.0.4",
		"@relayapi/db": "workspace:*",
		"fast-xml-parser": "^5.5.10",
		"hono": "^4.12.7",
		"resend": "^6.10.0",
		"stripe": "^20.4.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250312.0",
		"wrangler": "^4.72.0",
		"typescript": "^5.8"
	}
}
