{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["bun-types", "@cloudflare/workers-types"],
    "outDir": "./dist",
    // typecheck-only (noEmit); the @relayapi/* paths pull workspace source into
    // the program, so root the project at the repo root to satisfy TS 6.0's
    // tightened "rootDir must contain all source files" check (TS6059).
    "rootDir": "../..",
    "paths": {
      "@relayapi/db": ["../../packages/db/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["scripts"]
}
