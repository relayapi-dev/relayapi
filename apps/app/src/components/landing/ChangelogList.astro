---
import { changelog, LANDING_LINKS } from "./data";
import Container from "./Container.astro";
---

<!-- ================= CHANGELOG ================= -->
<Container as="section" class="py-12">
  <h2 class="mb-7 text-[clamp(24px,2.4vw,34px)] font-medium tracking-[-0.03em]">Changelog</h2>
  <div class="flex flex-col">
    {changelog.map((c) => (
      <a
        href={LANDING_LINKS.changelog}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-[22px] border-t border-landing-ink/[0.1] px-1 py-[19px] transition-opacity duration-150 hover:opacity-60"
      >
        <span class="w-[100px] shrink-0 text-[13px] text-[#9a968c] [font-family:var(--font-mono-landing)]">{c.date}</span>
        <span class="flex-1 text-[16px] text-landing-ink">{c.title}</span>
        <span class="text-[16px] text-[#9a968c]">→</span>
      </a>
    ))}
  </div>
  <a
    href={LANDING_LINKS.changelog}
    target="_blank"
    rel="noopener noreferrer"
    class="mt-[26px] inline-block text-[15px] font-medium text-landing-accent!"
  >See what's new in RelayAPI →</a>
</Container>
