---
import { changelog, LANDING_LINKS } from "./data";
---

<!-- ================= CHANGELOG ================= -->
<section style="max-width:1240px; margin:0 auto; padding:48px 32px;">
  <h2 style="font-size:clamp(24px,2.4vw,34px); letter-spacing:-0.03em; font-weight:500; margin:0 0 28px;">Changelog</h2>
  <div style="display:flex; flex-direction:column;">
    {changelog.map((c) => (
      <a href={LANDING_LINKS.changelog} target="_blank" rel="noopener noreferrer" class="changelog-row" style="display:flex; align-items:center; gap:22px; padding:19px 4px; border-top:1px solid rgba(26,24,21,0.1); transition:opacity .15s;">
        <span style={`font-size:13px; font-family:var(--font-mono-landing); color:#9A968C; width:100px; flex-shrink:0;`}>{c.date}</span>
        <span style="font-size:16px; color:#1A1815; flex:1;">{c.title}</span>
        <span style="font-size:16px; color:#9A968C;">→</span>
      </a>
    ))}
  </div>
  <a href={LANDING_LINKS.changelog} target="_blank" rel="noopener noreferrer" style="display:inline-block; margin-top:26px; font-size:15px; font-weight:500; color:#CB5A2C;">See what's new in RelayAPI →</a>
</section>

<style>
  .changelog-row:hover {
    opacity: 0.6;
  }
</style>
