---
import { frontier, LANDING_LINKS } from "./data";

function cardHref(link: string): string {
  if (link === "Explore platforms") return LANDING_LINKS.pricing;
  return LANDING_LINKS.docs;
}
---

<section style="max-width:1240px; margin:0 auto; padding:clamp(64px,8vw,104px) 32px 40px;">
  <h2 style="font-size:clamp(30px,3.2vw,44px); letter-spacing:-0.03em; font-weight:500; margin:0 0 48px; max-width:22ch;">Stay on the frontier of social.</h2>
  <div data-reveal style="display:grid; grid-template-columns:repeat(3,1fr); gap:22px;">
    {frontier.map((f) => (
      <div style="background:#EAE7DF; border-radius:20px; overflow:hidden;">
        <div style={`height:170px; background:${f.bg}; display:flex; align-items:center; justify-content:center;`}>
          <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="#1A1815" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.7;"><path d={f.icon}></path></svg>
        </div>
        <div style="padding:24px;">
          <h3 style="font-size:19px; font-weight:600; letter-spacing:-0.01em; margin:0 0 8px;">{f.title}</h3>
          <p style="font-size:14.5px; color:#6E6A62; line-height:1.55; margin:0 0 14px;">{f.body}</p>
          <a
            href={cardHref(f.link)}
            class="frontier-link"
            style="font-size:14px; font-weight:500; color:#CB5A2C;"
            target={cardHref(f.link).startsWith("https://") ? "_blank" : undefined}
            rel={cardHref(f.link).startsWith("https://") ? "noopener noreferrer" : undefined}
          >{f.link} →</a>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .frontier-link:hover {
    text-decoration: underline;
  }
</style>
