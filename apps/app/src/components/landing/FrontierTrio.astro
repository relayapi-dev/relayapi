---
import { frontier, LANDING_LINKS } from "./data";
import Container from "./Container.astro";

function cardHref(link: string): string {
  if (link === "Explore platforms") return LANDING_LINKS.pricing;
  return LANDING_LINKS.docs;
}
---

<Container as="section" class="pt-[clamp(4rem,8vw,6.5rem)] pb-10">
  <h2 class="mb-12 max-w-[22ch] text-[clamp(30px,3.2vw,44px)] font-medium tracking-[-0.03em]">Stay on the frontier of social.</h2>
  <div data-reveal class="grid grid-cols-3 gap-[22px]">
    {frontier.map((f) => (
      <div class="overflow-hidden rounded-[20px] bg-[#eae7df]">
        <div
          class="flex h-[170px] items-center justify-center bg-[var(--icon-bg)]"
          style={`--icon-bg:${f.bg}`}
        >
          <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="#1A1815" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="opacity-70"><path d={f.icon}></path></svg>
        </div>
        <div class="p-6">
          <h3 class="mb-2 text-[19px] font-semibold tracking-[-0.01em]">{f.title}</h3>
          <p class="mb-3.5 text-[14.5px] leading-[1.55] text-[#6e6a62]">{f.body}</p>
          <a
            href={cardHref(f.link)}
            class="text-[14px] font-medium text-landing-accent! hover:underline"
            target={cardHref(f.link).startsWith("https://") ? "_blank" : undefined}
            rel={cardHref(f.link).startsWith("https://") ? "noopener noreferrer" : undefined}
          >{f.link} →</a>
        </div>
      </div>
    ))}
  </div>
</Container>
