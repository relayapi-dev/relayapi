---
import Container from "./Container.astro";
import { frontier, LANDING_LINKS, PLATFORM_PATHS } from "./data";

// Each card links somewhere honest: the platforms card → pricing (the page that
// lists every network), the other two → the docs. Index-keyed so the data stays
// copy-only.
const hrefs = [LANDING_LINKS.pricing, LANDING_LINKS.docs, LANDING_LINKS.docs];

// Proof, not decoration. A short fan of real brand glyphs for "one call → every
// platform" (6 shown + 15 more = the honest 21).
const apiGlyphs = [
	PLATFORM_PATHS.x,
	PLATFORM_PATHS.instagram,
	PLATFORM_PATHS.linkedin,
	PLATFORM_PATHS.tiktok,
	PLATFORM_PATHS.youtube,
	PLATFORM_PATHS.threads,
];
// Aspect ratios the media pipeline auto-targets.
const mediaSpecs = ["1:1", "4:5", "9:16", "16:9"];
// SDKs we ship.
const sdks = ["TypeScript", "Python", "Go", "Java"];

const chip =
	"rounded-full border border-landing-line bg-landing-card px-2.5 py-1 text-[0.75rem] text-landing-ink [font-family:var(--font-mono-landing)]";
---

<Container
	as="section"
	class="pt-[clamp(4rem,8vw,6rem)] pb-[clamp(1.5rem,3vw,2.5rem)]"
>
	<h2
		class="mb-[clamp(2rem,4vw,3rem)] max-w-[22ch] text-[clamp(1.75rem,3vw,2.75rem)] font-medium tracking-[-0.03em] text-landing-ink"
	>
		Stay on the frontier of social.
	</h2>

	<div data-reveal class="grid grid-cols-1 gap-2.5 md:grid-cols-3">
		{
			frontier.map((f, i) => (
				<article class="flex flex-col rounded-md bg-landing-card p-[clamp(1.25rem,1.6vw,1.5rem)]">
					{/* honest micro-surface — a distinct proof per capability */}
					<div class="mb-6 flex min-h-[8.5rem] flex-col justify-center rounded-md border border-landing-line bg-landing-page p-5">
						{i === 0 && (
							<div>
								<code class="text-[0.8125rem] text-landing-ink [font-family:var(--font-mono-landing)]">
									<span class="text-landing-accent">POST</span> /v1/posts
								</code>
								<div class="mt-4 flex flex-wrap items-center gap-2.5">
									{apiGlyphs.map((d) => (
										<svg
											viewBox="0 0 24 24"
											fill="currentColor"
											aria-hidden="true"
											class="size-[1.125rem] text-landing-ink/70"
										>
											<path d={d} />
										</svg>
									))}
									<span class="text-[0.75rem] text-landing-muted [font-family:var(--font-mono-landing)]">
										+15
									</span>
								</div>
							</div>
						)}
						{i === 1 && (
							<div>
								<div class="text-[0.6875rem] uppercase tracking-[0.1em] text-landing-muted [font-family:var(--font-mono-landing)]">
									one upload →
								</div>
								<div class="mt-3 flex flex-wrap gap-2">
									{mediaSpecs.map((s) => (
										<span class={chip}>{s}</span>
									))}
								</div>
							</div>
						)}
						{i === 2 && (
							<div>
								<div class="flex flex-wrap gap-2">
									{sdks.map((s) => (
										<span class="rounded-full border border-landing-line bg-landing-card px-3 py-1 text-[0.75rem] text-landing-ink">
											{s}
										</span>
									))}
								</div>
								<code class="mt-4 block text-[0.75rem] text-landing-muted [font-family:var(--font-mono-landing)]">
									on <span class="text-landing-ink">post.published</span> →
									webhook
								</code>
							</div>
						)}
					</div>

					<h3 class="mb-2 text-[1.1875rem] font-semibold tracking-[-0.01em] text-landing-ink">
						{f.title}
					</h3>
					<p class="mb-4 text-[0.9375rem] leading-[1.55] text-landing-muted">
						{f.body}
					</p>
					<a
						href={hrefs[i]}
						class="mt-auto inline-block text-[0.875rem] font-medium text-landing-accent! transition-opacity duration-150 hover:opacity-70"
						target={hrefs[i].startsWith("https://") ? "_blank" : undefined}
						rel={
							hrefs[i].startsWith("https://")
								? "noopener noreferrer"
								: undefined
						}
					>
						{f.link} →
					</a>
				</article>
			))
		}
	</div>
</Container>
