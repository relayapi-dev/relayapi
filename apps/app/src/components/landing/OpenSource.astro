---
import Container from "./Container.astro";
import { LANDING_LINKS } from "./data";

// A real self-host session — proof the "run it yourself" claim is true, in the
// same window-chrome vocabulary as the Feature sections (just on dark).
const terminal: { text: string; prompt?: boolean; ok?: boolean }[] = [
	{ prompt: true, text: "git clone github.com/relayapi-dev/relayapi" },
	{ prompt: true, text: "bun install" },
	{ prompt: true, text: "bun run deploy" },
	{ ok: true, text: "Deployed to your Cloudflare account" },
];
---

<!-- ================= OPEN SOURCE ================= -->
<Container as="section" class="py-[clamp(1.5rem,3vw,2.5rem)]">
	<div
		data-reveal
		class="grid grid-cols-1 items-center gap-[clamp(2rem,4vw,3.5rem)] rounded-md bg-landing-ink p-[clamp(2rem,5vw,4rem)] lg:grid-cols-2"
	>
		<div>
			<h2
				class="mb-4 max-w-[18ch] text-[clamp(1.75rem,3.2vw,2.625rem)] font-medium tracking-[-0.03em] text-[#f3f1ea]"
			>
				Open source. Yours to run.
			</h2>
			<p class="mb-6 max-w-[46ch] text-[1.0625rem] leading-[1.5] text-[#8c887e]">
				Prefer to host it yourself? Run the entire platform on your own
				infrastructure — same API, no vendor lock-in.
			</p>
			<div class="mb-7 flex flex-wrap gap-2">
				{
					["Open source", "Self-hostable", "No lock-in"].map((c) => (
						<span class="rounded-full border border-landing-line-dark px-3 py-1 text-[0.75rem] text-[#d7d2c7]">
							{c}
						</span>
					))
				}
			</div>
			<a
				href={LANDING_LINKS.github}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-2.5 rounded-full bg-[#f3f1ea] px-[1.375rem] py-[0.8125rem] text-[0.9375rem] font-medium text-landing-ink! transition-opacity duration-150 hover:opacity-[0.88]"
			>
				<svg
					width="18"
					height="18"
					viewBox="0 0 24 24"
					class="fill-landing-ink"
					aria-hidden="true"
					><path
						d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
					></path></svg
				>View on GitHub</a
			>
		</div>

		<!-- terminal: honest proof you can self-host -->
		<div
			class="overflow-hidden rounded-feature-window border border-landing-line-dark bg-landing-panel-dark"
		>
			<div
				class="flex items-center gap-[7px] border-b border-landing-line-dark px-4 py-2.5"
			>
				<span class="size-[10px] rounded-full bg-white/15"></span>
				<span class="size-[10px] rounded-full bg-white/15"></span>
				<span class="size-[10px] rounded-full bg-white/15"></span>
				<span
					class="ml-2 text-[0.75rem] text-white/40 [font-family:var(--font-mono-landing)]"
					>bash</span
				>
			</div>
			<div
				class="space-y-2 p-5 text-[0.8125rem] leading-relaxed [font-family:var(--font-mono-landing)]"
			>
				{
					terminal.map((l) => (
						<div class="flex gap-2">
							{l.prompt && (
								<span class="shrink-0 select-none text-[#8c887e]">$</span>
							)}
							{l.ok && (
								<span class="shrink-0 select-none text-[#7fb88a]">✓</span>
							)}
							<span class={l.ok ? "text-[#7fb88a]" : "text-[#d7d2c7]"}>
								{l.text}
							</span>
						</div>
					))
				}
			</div>
		</div>
	</div>
</Container>
