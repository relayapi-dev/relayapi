---
import Container from "./Container.astro";
import { blog } from "./data";
---

<!-- ================= BLOG HIGHLIGHTS ================= -->
<Container as="section" class="py-[clamp(3rem,6vw,4.5rem)]">
	<h2
		class="mb-7 text-[clamp(1.5rem,2.4vw,2.125rem)] font-medium tracking-[-0.03em] text-landing-ink"
	>
		Recent highlights
	</h2>
	<div data-reveal class="grid grid-cols-1 gap-2.5 sm:grid-cols-2 lg:grid-cols-4">
		{
			blog.map((b) => (
				<a
					href="#"
					class="group flex min-h-[11.5rem] flex-col rounded-md border border-landing-line bg-landing-card p-5 transition-colors duration-200 hover:bg-landing-page"
				>
					<span class="text-[0.6875rem] uppercase tracking-[0.08em] text-landing-accent [font-family:var(--font-mono-landing)]">
						{b.tag}
					</span>
					<h3 class="mt-3 text-[1.0625rem] font-semibold leading-[1.3] tracking-[-0.01em] text-landing-ink">
						{b.title}
					</h3>
					<div class="mt-auto flex items-center justify-between pt-6">
						<span class="text-[0.75rem] text-landing-muted">{b.meta}</span>
						<span class="text-landing-muted transition-all duration-150 group-hover:translate-x-1 group-hover:text-landing-accent">
							→
						</span>
					</div>
				</a>
			))
		}
	</div>
</Container>
