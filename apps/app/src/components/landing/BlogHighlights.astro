---
import { blog } from "./data";
---

<!-- ================= BLOG HIGHLIGHTS ================= -->
<section style="max-width:1240px; margin:0 auto; padding:48px 32px;">
  <h2 style="font-size:clamp(24px,2.4vw,34px); letter-spacing:-0.03em; font-weight:500; margin:0 0 28px;">Recent highlights</h2>
  <div data-reveal style="display:grid; grid-template-columns:repeat(4,1fr); gap:20px;">
    {blog.map((b) => (
      <a href="#" class="blog-card" style="display:block;">
        <div style={`height:140px; border-radius:16px; background:${b.bg}; margin-bottom:14px;`}></div>
        <div style={`font-size:11.5px; color:#9A968C; font-family:var(--font-mono-landing); margin-bottom:6px;`}>{b.tag}</div>
        <div style="font-size:15.5px; font-weight:500; letter-spacing:-0.01em; line-height:1.3; margin-bottom:6px;">{b.title}</div>
        <div style="font-size:12.5px; color:#9A968C;">{b.meta}</div>
      </a>
    ))}
  </div>
</section>
