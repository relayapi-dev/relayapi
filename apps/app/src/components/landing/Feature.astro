---
/**
 * Feature.astro — abstract landing "feature card" in the Cursor.com style.
 *
 * Geometry + type scale are measured from cursor.com's feature card and live as
 * tokens in globals.css (@theme): the caption uses `text-feature` (22px / 1.3 /
 * regular), the card is `bg-landing-card rounded-feature`, and the floating
 * window is `shadow-feature-window rounded-feature-window`. Nothing here
 * hardcodes a hex or a font size — change the look in one place (the tokens).
 *
 * Config:
 *   - `side`         which side the caption sits on (window bleeds off the other)
 *   - `panelTheme`   light or dark window chrome
 *   - `animation`    a distinct entrance per feature (see @theme feature-*)
 *   - `panelFill`    stretch the window top↔bottom (tall mocks) vs. float centered
 *
 * The window body is a <slot/>. The card uses the shared `data-reveal` engine
 * (index.astro); on enter it gains `.is-visible`, firing the window's
 * `animate-feature-*` entrance via the `group/feat` variant. A position wrapper
 * holds placement so the entrance transform never disturbs the layout.
 */
import Container from "./Container.astro";

interface Props {
	title: string;
	description: string;
	linkText: string;
	linkHref: string;
	/** Caption side; the floating window bleeds off the opposite edge. */
	side?: "left" | "right";
	panelTheme?: "light" | "dark";
	/** Centered label in the window's title bar. */
	windowTitle?: string;
	/** Per-feature entrance — keyed to the @theme feature-* utilities. */
	animation?: "rise" | "drift" | "zoom" | "tilt" | "unfold";
	/** Card min-height (a clamp() expression). */
	height?: string;
	/** Stretch the window from top inset to bottom inset (vs. float centered). */
	panelFill?: boolean;
	class?: string;
}

const {
	title,
	description,
	linkText,
	linkHref,
	side = "left",
	panelTheme = "light",
	windowTitle,
	animation = "rise",
	height = "clamp(560px,52vw,720px)",
	panelFill = false,
	class: className = "",
} = Astro.props;

const isExternal = linkHref.startsWith("http");
const panelLeft = side === "right"; // window opposite the caption
const isDark = panelTheme === "dark";

const animClass = {
	rise: "group-[.is-visible]/feat:animate-feature-rise",
	drift: "group-[.is-visible]/feat:animate-feature-drift",
	zoom: "group-[.is-visible]/feat:animate-feature-zoom",
	tilt: "group-[.is-visible]/feat:animate-feature-tilt",
	unfold: "group-[.is-visible]/feat:animate-feature-unfold",
}[animation];
---

<Container as="section" class:list={["py-[1.125rem]", className]}>
	<div
		data-reveal
		class="group/feat relative flex flex-col overflow-hidden rounded-feature bg-landing-card md:block md:min-h-[var(--feat-h)]"
		style={`--feat-h:${height}`}
	>
		<!-- caption — stacked on mobile; vertically centered in a ~28% column from md up
		     (cursor's caption is ~29% of the card width, leaving a clear gap to the window) -->
		<div
			class:list={[
				"z-[3] max-w-[420px] px-7 pt-8 md:absolute md:top-1/2 md:w-[27%] md:max-w-[22rem] md:-translate-y-1/2 md:p-0",
				side === "left" ? "md:left-[4%]" : "md:right-[4%]",
			]}
		>
			<h3
				class="text-feature font-normal tracking-feature text-landing-ink"
			>
				{title}
			</h3>
			<p
				class="text-feature font-normal tracking-feature text-landing-muted"
			>
				{description}
			</p>
			<a
				href={linkHref}
				class="mt-5 inline-block text-[16px] font-normal text-landing-accent! transition-opacity duration-200 hover:opacity-70"
				target={isExternal ? "_blank" : undefined}
				rel={isExternal ? "noopener noreferrer" : undefined}
			>
				{linkText} →
			</a>
		</div>

		<!-- window position wrapper — full-width below the caption on mobile; from md up it
		     spans the right ~62% of the card (left edge at 38%, bleeding ~7% off the outer
		     edge) and floats with an 8% top/bottom inset, mirroring cursor's geometry. This
		     can't collide with the caption (right edge ~34%) thanks to the ~4% gap. -->
		<div
			class:list={[
				"relative mt-7 w-full md:absolute md:mt-0 md:w-auto",
				panelFill
					? "md:top-[8%] md:bottom-[8%]"
					: "md:top-1/2 md:-translate-y-1/2",
				panelLeft
					? "md:left-[-7%] md:right-[36.5%]"
					: "md:left-[36.5%] md:right-[-7%]",
			]}
		>
			<!-- floating window (the animated element) -->
			<div
				class:list={[
					"flex h-full flex-col overflow-hidden rounded-feature-window shadow-feature-window",
					"motion-reduce:animate-none",
					animClass,
					isDark
						? "bg-landing-panel-dark text-[#D7D2C7]"
						: "bg-landing-panel",
				]}
			>
				<!-- window chrome -->
				<div
					class:list={[
						"relative flex shrink-0 items-center px-4 py-2",
						isDark
							? "border-b border-landing-line-dark"
							: "border-b border-landing-line",
					]}
				>
					<div class="flex gap-[7px]">
						<span
							class:list={[
								"size-[10px] rounded-full",
								isDark ? "bg-white/15" : "bg-black/10",
							]}></span>
						<span
							class:list={[
								"size-[10px] rounded-full",
								isDark ? "bg-white/15" : "bg-black/10",
							]}></span>
						<span
							class:list={[
								"size-[10px] rounded-full",
								isDark ? "bg-white/15" : "bg-black/10",
							]}></span>
					</div>
					<span
						class:list={[
							"absolute left-1/2 -translate-x-1/2 text-[12px]",
							isDark ? "text-white/55" : "text-landing-muted",
						]}>{windowTitle}</span
					>
				</div>

				<!-- window body -->
				<div class="min-h-0 flex-1 overflow-hidden">
					<slot />
				</div>
			</div>
		</div>
	</div>
</Container>
