---
/**
 * Feature.astro — abstract landing "feature card" in the Cursor.com style.
 *
 * A full-bleed rounded card with a text caption on one side and a floating
 * product window cropped off the opposite edge. Everything is configurable:
 *   - `side`         which side the caption sits on (window goes opposite)
 *   - `captionAlign` caption pinned to the top or bottom of the card
 *   - `panelTheme`   light or dark window chrome
 *   - `animation`    a distinct entrance per feature (see globals.css @theme)
 *
 * The window body is a <slot/>, so each feature supplies its own mockup. The
 * card uses the shared `data-reveal` scroll engine (index.astro); when it
 * enters the viewport the root gains `.is-visible`, which fires the window's
 * `animate-feature-*` entrance via the `group/feat` variant.
 */
interface Props {
	title: string;
	description: string;
	linkText: string;
	linkHref: string;
	/** Caption side; the floating window is rendered on the opposite edge. */
	side?: "left" | "right";
	captionAlign?: "top" | "bottom";
	panelTheme?: "light" | "dark";
	/** Centered label in the window's title bar. */
	windowTitle?: string;
	/** Per-feature entrance — keyed to the @animate-feature-* utilities. */
	animation?: "rise" | "drift" | "zoom" | "tilt" | "unfold";
	/** Card min-height (a clamp() expression). */
	height?: string;
	/** Floating window width (a min()/clamp() expression). */
	panelWidth?: string;
	/** Stretch the window from near the top to the bottom (vs. auto height). */
	panelFill?: boolean;
	class?: string;
}

const {
	title,
	description,
	linkText,
	linkHref,
	side = "left",
	captionAlign = "bottom",
	panelTheme = "light",
	windowTitle = "RelayAPI",
	animation = "rise",
	height = "clamp(560px,52vw,760px)",
	panelWidth = "min(900px,64%)",
	panelFill = false,
	class: className = "",
} = Astro.props;

const isExternal = linkHref.startsWith("http");
const panelLeft = side === "right"; // window opposite the caption

const animClass = {
	rise: "group-[.is-visible]/feat:animate-feature-rise",
	drift: "group-[.is-visible]/feat:animate-feature-drift",
	zoom: "group-[.is-visible]/feat:animate-feature-zoom",
	tilt: "group-[.is-visible]/feat:animate-feature-tilt",
	unfold: "group-[.is-visible]/feat:animate-feature-unfold",
}[animation];

const isDark = panelTheme === "dark";
---

<section class:list={["mx-auto max-w-[1480px] px-5 py-[18px]", className]}>
	<div
		data-reveal
		class="group/feat relative flex flex-col overflow-hidden rounded-[20px] bg-[#E9E7DF] md:block md:min-h-[var(--feat-h)] md:rounded-[30px]"
		style={`--feat-h:${height}`}
	>
		<!-- caption (stacked at top on mobile, absolutely placed on the configured side from md up) -->
		<div
			class:list={[
				"z-[3] max-w-[430px] px-7 pt-8 md:p-0 md:absolute",
				side === "left"
					? "md:left-[clamp(28px,4vw,64px)]"
					: "md:right-[clamp(28px,4vw,64px)]",
				captionAlign === "bottom"
					? "md:bottom-[clamp(40px,5vw,72px)]"
					: "md:top-[clamp(44px,5vw,72px)]",
			]}
		>
			<h3
				class="mb-1 text-[clamp(26px,2.5vw,34px)] font-semibold leading-[1.12] tracking-[-0.025em] text-[#1A1815]"
			>
				{title}
			</h3>
			<p
				class="mb-[18px] text-[clamp(18px,1.8vw,22px)] font-normal leading-[1.32] text-[#86827A]"
			>
				{description}
			</p>
			<a
				href={linkHref}
				class="text-[17px] font-medium text-[#CB5A2C] transition-opacity duration-200 hover:opacity-80"
				target={isExternal ? "_blank" : undefined}
				rel={isExternal ? "noopener noreferrer" : undefined}
			>
				{linkText} →
			</a>
		</div>

		<!-- floating window: full-width below the caption on mobile, cropped off the opposite edge from md up -->
		<div
			class:list={[
				"relative mt-7 w-full overflow-hidden border shadow-[0_30px_80px_-28px_rgba(40,28,12,0.45)] [transform-style:preserve-3d]",
				"md:absolute md:bottom-0 md:mt-0 md:w-[var(--feat-pw)]",
				"motion-reduce:animate-none",
				animClass,
				panelLeft
					? "rounded-tr-[18px] md:left-0 md:rounded-tl-none"
					: "rounded-tl-[18px] md:right-0",
				panelFill ? "md:top-12" : "",
				isDark
					? "border-white/10 bg-[#1B1915] text-[#D7D2C7]"
					: "border-[rgba(26,24,21,0.07)] bg-[#F4F2EC]",
			]}
			style={`--feat-pw:${panelWidth}`}
		>
			<!-- window chrome -->
			<div
				class:list={[
					"relative flex items-center px-4 py-[13px]",
					isDark
						? "border-b border-white/[0.06] bg-[#221F18]"
						: "border-b border-[rgba(26,24,21,0.06)] bg-[#EDEBE4]",
				]}
			>
				<div class="flex gap-[7px]">
					<span
						class:list={[
							"size-[11px] rounded-full",
							isDark ? "bg-[#3C382F]" : "bg-[#CFC9BD]",
						]}></span>
					<span
						class:list={[
							"size-[11px] rounded-full",
							isDark ? "bg-[#3C382F]" : "bg-[#CFC9BD]",
						]}></span>
					<span
						class:list={[
							"size-[11px] rounded-full",
							isDark ? "bg-[#3C382F]" : "bg-[#CFC9BD]",
						]}></span>
				</div>
				<span
					class:list={[
						"absolute left-1/2 -translate-x-1/2 text-[13px]",
						isDark ? "text-[#8C887E]" : "text-[#6E6A62]",
					]}>{windowTitle}</span
				>
			</div>

			<!-- window body -->
			<div class:list={["overflow-hidden", panelFill ? "md:h-full" : ""]}>
				<slot />
			</div>
		</div>
	</div>
</section>
