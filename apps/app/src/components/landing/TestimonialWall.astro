---
import { testimonials } from "./data";
---

<section style="background:#1A1815; color:#ECE8DF;">
  <div style="max-width:1240px; margin:0 auto; padding:clamp(64px,8vw,104px) 32px;">
    <h2 style="font-size:clamp(32px,4vw,56px); letter-spacing:-0.035em; font-weight:500; margin:0 0 8px; color:#F3F1EA; text-align:center;">The new way to post.</h2>
    <p style="text-align:center; color:#8C887E; font-size:17px; margin:0 0 56px;">Hear from our totally real users.</p>
    <div style="columns:3; column-gap:22px;">
      {testimonials.map((t) => (
        <div style="break-inside:avoid; margin-bottom:22px; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); border-radius:18px; padding:26px;">
          <p style="font-size:15px; line-height:1.6; color:#D7D2C7; margin:0 0 22px;">{t.quote}</p>
          <div style="display:flex; align-items:center; gap:13px;">
            <span style={`width:40px; height:40px; border-radius:50%; background:${t.avatarBg}; display:flex; align-items:center; justify-content:center; font-size:15px; font-weight:600; color:#1A1815; flex-shrink:0;`}>{t.initial}</span>
            <div><div style="font-size:14px; font-weight:600; color:#F3F1EA;">{t.name}</div><div style="font-size:12.5px; color:#8C887E;">{t.role}</div></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
