---
import { testimonials } from "./data";
---

<section class="mx-auto max-w-[1240px] px-6 sm:px-8 py-[clamp(64px,8vw,104px)]">
	<div data-reveal>
		<h2
			class="text-center text-[clamp(30px,4.4vw,52px)] font-medium leading-[1.05] tracking-[-0.035em] text-[#1a1815]"
		>
			The new way to post.
		</h2>
		<p class="mt-3 text-center text-[17px] text-[#8c887e]">
			Hear from our totally real users.
		</p>
	</div>

	<div
		data-reveal
		class="mt-12 grid grid-cols-1 gap-px overflow-hidden rounded-[2px] bg-[#1a1815]/10 sm:mt-14 sm:grid-cols-2 lg:grid-cols-3"
	>
		{
			testimonials.map((t) => (
				<figure class="flex h-full flex-col bg-[#f4f2ec] p-6 sm:p-7 lg:p-8">
					<blockquote class="text-[15px] leading-[1.6] text-[#3c3a33]">
						{`“${t.quote}”`}
					</blockquote>
					<figcaption class="mt-auto flex items-center gap-3 pt-7">
						<span
							style={`--avatar-bg:${t.avatarBg}`}
							class="flex size-9 shrink-0 items-center justify-center rounded-full bg-[var(--avatar-bg)] text-[14px] font-semibold text-[#1a1815]"
						>
							{t.initial}
						</span>
						<div class="min-w-0">
							<div class="truncate text-[14px] font-semibold text-[#1a1815]">
								{t.name}
							</div>
							<div class="text-[12.5px] text-[#8c887e]">{t.role}</div>
						</div>
					</figcaption>
				</figure>
			))
		}
	</div>
</section>
