---
import Container from "./Container.astro";
import { footerCols } from "./data";

/**
 * LandingFooter — "Horizon".
 *
 * The page bottoms out into a painterly dawn landscape (public/footer.png):
 * a luminous sky fills the top, soft blue-grey mountains and a still lake sit
 * along the bottom. The functional content (brand mark, tagline, four link
 * columns parted by hairline dividers) stays compact in the top sky band, in
 * solid black; generous bottom spacing then lets the landscape breathe through
 * as an open horizon before the legal bar.
 *
 * A top-weighted scrim (landing-bg → transparent) sits over the image but under
 * the text so the black ink reads crisply across the peach-glow centre while
 * the landscape still glows through.
 *
 * Pure Tailwind v4 utilities — no inline styles, no <style> block. Hover/state
 * is driven with `hover:` / `group-hover:` variants; colours and spacing come
 * from the shared landing theme tokens (--color-landing-ink/-accent/-line/-bg).
 */
---

<!-- ================= FOOTER ================= -->
<footer
	class="relative isolate overflow-hidden bg-landing-bg bg-[url('/footer.png')] bg-cover bg-bottom bg-no-repeat"
>
	{
		/* Legibility scrim — lightens the top sky band behind the functional
      content, then fades to nothing so the mountains and lake breathe through
      lower down where the open horizon and the legal bar sit. */
	}
	<div
		aria-hidden="true"
		class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[58%] bg-gradient-to-b from-landing-bg via-landing-bg/65 to-transparent"
	>
	</div>

	{/* Primary grid: brand block + four link columns, parted by hairlines */}
	<Container
		class="grid grid-cols-2 gap-x-8 gap-y-12 pt-16 pb-48 sm:grid-cols-3 lg:grid-cols-[1.7fr_1fr_1fr_1fr_1fr] lg:gap-x-0 lg:pb-56 lg:pt-20 xl:pb-64"
	>
		{/* Brand */}
		<div
			class="col-span-2 max-w-[30ch] sm:col-span-3 lg:col-span-1 lg:pr-10"
		>
			<a href="/" class="group inline-flex items-center gap-2.5">
				<span
					class="flex size-7 items-center justify-center rounded-[0.45rem] bg-landing-ink transition-transform duration-200 ease-out group-hover:-rotate-6 motion-reduce:transition-none motion-reduce:group-hover:rotate-0"
				>
					<svg
						class="size-[0.94rem] fill-landing-bg"
						viewBox="0 0 150 150"
						aria-hidden="true"
					>
						<path
							fill-rule="evenodd"
							d="M34.82,18.54C16.52,18.54,1.49,33.56,1.49,51.87s15.02,33.33,33.33,33.33h80.69c6.95,0,12.28,5.33,12.28,12.28s-5.33,12.28-12.28,12.28H33.07c-5.77-.01-10.52,4.74-10.52,10.51s4.76,10.52,10.52,10.52h82.44c18.31,0,33.33-15.02,33.33-33.33s-15.02-33.33-33.33-33.33H34.82c-6.95,0-12.28-5.33-12.28-12.28s5.33-12.28,12.28-12.28h82.45c5.77.01,10.52-4.74,10.52-10.51s-4.76-10.52-10.52-10.52H34.82Z"
						></path>
					</svg>
				</span>
				<span
					class="text-base font-semibold tracking-[0.05em] text-landing-ink"
					>RELAYAPI</span
				>
			</a>
			<p
				class="mt-3.5 text-[0.92rem] leading-relaxed text-landing-ink/75"
			>
				Unified social media API — post to 21 platforms with a single
				call.
			</p>
		</div>

		{/* Link columns: hairline divider on the leading edge from lg up */}
		{
			footerCols.map((col) => (
				<nav
					aria-label={col.title}
					class="flex flex-col lg:border-l lg:border-landing-line lg:pl-8"
				>
					<h2 class="mb-5 text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-landing-ink">
						{col.title}
					</h2>
					<ul class="flex flex-col gap-3.5">
						{col.links.map((lnk) => (
							<li>
								<a
									href="#"
									class="group inline-flex w-fit text-[0.9rem] text-landing-ink/75 transition-colors duration-150 hover:text-landing-ink focus-visible:text-landing-ink focus-visible:outline-none motion-reduce:transition-none"
								>
									<span class="relative">
										{lnk}
										<span class="absolute inset-x-0 -bottom-0.5 h-px origin-left scale-x-0 bg-landing-accent transition-transform duration-200 ease-out group-hover:scale-x-100 group-focus-visible:scale-x-100 motion-reduce:transition-none" />
									</span>
								</a>
							</li>
						))}
					</ul>
				</nav>
			))
		}
	</Container>

	{
		/* Legal bar — rests over the clearest part of the horizon, ink stays black */
	}
	<Container
		class="relative flex flex-col-reverse items-start gap-3 pb-10 text-[0.8rem] text-landing-ink/80 sm:flex-row sm:items-center sm:justify-between"
	>
		<span>© 2026 Relay. All rights reserved.</span>
		<button
			type="button"
			class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-landing-ink/80 transition-colors duration-150 hover:bg-landing-ink/[0.06] hover:text-landing-ink focus-visible:bg-landing-ink/[0.06] focus-visible:text-landing-ink focus-visible:outline-none motion-reduce:transition-none"
		>
			<svg
				class="size-3.5 fill-none stroke-current"
				viewBox="0 0 24 24"
				stroke-width="1.6"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<circle cx="12" cy="12" r="9.5"></circle>
				<path
					d="M2.5 12h19M12 2.5c2.6 2.6 4 5.9 4 9.5s-1.4 6.9-4 9.5c-2.6-2.6-4-5.9-4-9.5s1.4-6.9 4-9.5Z"
				></path>
			</svg>
			English
		</button>
	</Container>
</footer>
