---
import { footerCols } from "./data";
---

<footer style="border-top:1px solid rgba(26,24,21,0.1);">
  <div style="max-width:1240px; margin:0 auto; padding:56px 32px 40px; display:grid; grid-template-columns:1.6fr 1fr 1fr 1fr 1fr; gap:32px;">
    <div>
      <div style="display:flex; align-items:center; gap:10px; margin-bottom:14px;">
        <span style="width:26px; height:26px; border-radius:7px; background:#1A1815; display:flex; align-items:center; justify-content:center;"><svg width="15" height="15" viewBox="0 0 150 150" fill="#F3F1EA"><path fill-rule="evenodd" d="M34.82,18.54C16.52,18.54,1.49,33.56,1.49,51.87s15.02,33.33,33.33,33.33h80.69c6.95,0,12.28,5.33,12.28,12.28s-5.33,12.28-12.28,12.28H33.07c-5.77-.01-10.52,4.74-10.52,10.51s4.76,10.52,10.52,10.52h82.44c18.31,0,33.33-15.02,33.33-33.33s-15.02-33.33-33.33-33.33H34.82c-6.95,0-12.28-5.33-12.28-12.28s5.33-12.28,12.28-12.28h82.45c5.77.01,10.52-4.74,10.52-10.51s-4.76-10.52-10.52-10.52H34.82Z"></path></svg></span>
        <span style="font-size:16px; font-weight:600; letter-spacing:0.05em;">RELAYAPI</span>
      </div>
      <p style="font-size:13px; color:#9A968C; max-width:26ch; line-height:1.55; margin:0;">Unified social media API — post to 21 platforms with a single call.</p>
    </div>
    {footerCols.map((col) => (
      <div>
        <div style="font-size:13px; font-weight:600; margin-bottom:14px;">{col.title}</div>
        <div style="display:flex; flex-direction:column; gap:11px;">
          {col.links.map((lnk) => (
            <a href="#" class="footer-link" style="font-size:13.5px; color:#6E6A62; transition:color .15s;">{lnk}</a>
          ))}
        </div>
      </div>
    ))}
  </div>
  <div style="max-width:1240px; margin:0 auto; padding:20px 32px 44px; display:flex; justify-content:space-between; align-items:center; font-size:12.5px; color:#9A968C; border-top:1px solid rgba(26,24,21,0.07);">
    <span>© 2026 Relay. All rights reserved.</span>
    <span>🌐 English</span>
  </div>
</footer>

<style>
  .footer-link:hover {
    color: #1A1815;
  }
</style>
