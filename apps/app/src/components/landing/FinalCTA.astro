---
import { LANDING_LINKS } from "./data";
---

<!-- ================= FINAL CTA ================= -->
<section style="max-width:1240px; margin:0 auto; padding:clamp(72px,9vw,120px) 32px; text-align:center;">
  <h2 style="font-size:clamp(40px,6vw,84px); letter-spacing:-0.04em; font-weight:500; margin:0 0 36px; color:#1A1815;">Try RelayAPI now.</h2>
  <div style="display:flex; gap:14px; justify-content:center; flex-wrap:wrap;">
    <a href={LANDING_LINKS.signup} class="cta-primary" style="font-size:17px; font-weight:500; color:#F3F1EA; background:#1A1815; padding:15px 30px; border-radius:999px; transition:opacity .15s;">Get started →</a>
    <a href={LANDING_LINKS.signup} class="cta-secondary" style="font-size:17px; font-weight:500; color:#1A1815; background:#E4E1D9; padding:15px 30px; border-radius:999px; transition:background .15s;">Request a demo →</a>
  </div>
</section>

<style>
  .cta-primary:hover {
    opacity: 0.88;
  }
  .cta-secondary:hover {
    background: #DBD7CC;
  }
</style>
