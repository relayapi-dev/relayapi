---
import Container from "./Container.astro";
import { LANDING_LINKS, platformLogos } from "./data";
---

<Container
	as="section"
	class="pt-[clamp(4rem,8vw,7rem)] pb-[clamp(2.5rem,5vw,4.1875rem)] text-center"
>
	<h1
		class="mx-auto mb-[clamp(1.5rem,3vw,2rem)] max-w-[20ch] text-balance text-[clamp(1.875rem,3.2vw,2.75rem)] font-medium leading-[1.15] tracking-[-0.02em] text-[#1a1815]"
	>
		The agent-native way to post everywhere.
	</h1>
	<div class="flex flex-wrap justify-center gap-[0.625rem]">
		<a
			href={LANDING_LINKS.signup}
			class="inline-flex items-center gap-2 rounded-full bg-[#1a1815] px-[1.375rem] py-[0.8125rem] text-[1rem] font-medium text-[#f3f1ea]! transition-opacity duration-150 hover:opacity-[0.88]"
		>
			<svg
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
				class="size-[1.125rem]"
			>
				<rect x="2" y="5" width="20" height="14" rx="2"></rect>
				<line x1="2" y1="10" x2="22" y2="10"></line>
				<line x1="2" y1="2" x2="22" y2="22"></line>
			</svg>
			Start free</a
		>
		<a
			href={LANDING_LINKS.selfhost}
			class="inline-flex items-center gap-2 rounded-full bg-[#e4e1d9] px-[1.375rem] py-[0.8125rem] text-[1rem] font-medium text-[#1a1815]! transition-colors duration-150 hover:bg-[#dbd7cc]"
		>
			<svg
				viewBox="0 0 24 24"
				fill="currentColor"
				aria-hidden="true"
				class="size-[1.125rem]"
				><path
					d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
				></path></svg
			>Host yourself</a
		>
	</div>

	<!-- mini platform glyphs: an honest "post to all of these" trust signal -->
	<div
		aria-label="Publish to every supported platform"
		class="mx-auto mt-[clamp(2rem,4vw,3rem)] flex max-w-[40rem] flex-wrap items-center justify-center gap-x-[1.25rem] gap-y-[0.75rem]"
	>
		{
			platformLogos.map((p) => (
				<a
					href={`/product/${p.slug}`}
					title={p.name}
					aria-label={`${p.name} API`}
					class="inline-flex text-[#8c887e]! transition-colors duration-200 hover:text-[#1a1815]!"
				>
					<svg
						viewBox="0 0 24 24"
						fill="currentColor"
						aria-hidden="true"
						class="size-[1.125rem]"
					>
						<path d={p.glyph} />
					</svg>
				</a>
			))
		}
	</div>
</Container>
