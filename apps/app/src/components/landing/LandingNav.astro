---
import Container from "./Container.astro";
import { LANDING_LINKS } from "./data";
---

{
	/* Fixed top bar — sizing/structure modeled on cursor.com's header
    (52px tall, solid bar, pill buttons, 7.5px action gap), mapped onto
    RelayAPI's cream/ink palette. The spacer keeps the hero from sliding
    under the fixed bar. */
}
<header
	class="fixed left-0 top-0 z-[60] flex h-[52px] w-full items-center bg-landing-page"
>
	<Container
		as="nav"
		class="relative flex items-center justify-between gap-4 max-[400px]:px-[0.875rem]"
	>
		<a href="/" class="flex shrink-0 items-center gap-2.5">
			<span
				class="flex size-[26px] items-center justify-center rounded-[7px] bg-landing-ink"
				><svg
					width="15"
					height="15"
					viewBox="0 0 150 150"
					class="fill-[#f3f1ea]"
					><path
						fill-rule="evenodd"
						d="M34.82,18.54C16.52,18.54,1.49,33.56,1.49,51.87s15.02,33.33,33.33,33.33h80.69c6.95,0,12.28,5.33,12.28,12.28s-5.33,12.28-12.28,12.28H33.07c-5.77-.01-10.52,4.74-10.52,10.51s4.76,10.52,10.52,10.52h82.44c18.31,0,33.33-15.02,33.33-33.33s-15.02-33.33-33.33-33.33H34.82c-6.95,0-12.28-5.33-12.28-12.28s5.33-12.28,12.28-12.28h82.45c5.77.01,10.52-4.74,10.52-10.51s-4.76-10.52-10.52-10.52H34.82Z"
					></path></svg
				></span
			>
			<span
				class="text-[16px] font-semibold tracking-[0.04em] text-landing-ink max-[400px]:hidden"
				>RELAYAPI</span
			>
		</a>
		<div
			class="absolute left-1/2 top-1/2 flex -translate-x-1/2 -translate-y-1/2 items-center justify-center gap-[clamp(14px,2vw,28px)] max-[860px]:hidden"
		>
			<a
				href="#"
				class="text-[14px] text-[#3a3833]! transition-colors duration-150 hover:text-landing-ink!"
				>Product</a
			>
			<a
				href="#"
				class="text-[14px] text-[#3a3833]! transition-colors duration-150 hover:text-landing-ink!"
				>Platforms</a
			>
			<a
				href={LANDING_LINKS.pricing}
				class="text-[14px] text-[#3a3833]! transition-colors duration-150 hover:text-landing-ink!"
				>Pricing</a
			>
			<a
				href={LANDING_LINKS.docs}
				class="text-[14px] text-[#3a3833]! transition-colors duration-150 hover:text-landing-ink!"
				target="_blank"
				rel="noopener noreferrer">Docs</a
			>
		</div>
		<div class="flex shrink-0 items-center gap-2 max-[400px]:gap-1.5">
			<a
				href={LANDING_LINKS.login}
				class="px-2 py-1.5 text-[14px] text-[#3a3833]! transition-colors duration-150 hover:text-landing-ink! max-[560px]:hidden"
				>Sign in</a
			>
			<a
				href={LANDING_LINKS.github}
				class="whitespace-nowrap rounded-full border border-landing-ink/[0.18] bg-transparent px-3.5 py-[7px] text-[14px] leading-none text-landing-ink! transition-[background-color,border-color,opacity] duration-150 hover:border-landing-ink/30 hover:bg-landing-ink/[0.04]"
				target="_blank"
				rel="noopener noreferrer">GitHub</a
			>
			<a
				href={LANDING_LINKS.signup}
				class="whitespace-nowrap rounded-full border border-landing-ink bg-landing-ink px-3.5 py-[7px] text-[14px] font-medium leading-none text-[#f3f1ea]! transition-[background-color,border-color,opacity] duration-150 hover:bg-landing-ink hover:opacity-[0.88]"
				>Get started</a
			>
		</div>
	</Container>
</header>
<div class="h-[52px]" aria-hidden="true"></div>
