---
import Feature from "./Feature.astro";
import { LANDING_LINKS } from "./data";
---

<!-- FEATURE 1 — agentic chat + plan doc, caption left, window drifts in from the right -->
<Feature
	title="Agents that post for you"
	description="Hand off a campaign and Relay drafts, formats, and schedules it across every platform — while you focus on the message."
	linkText="Learn about social agents"
	linkHref={LANDING_LINKS.docs}
	side="left"
	windowTitle="RelayAPI"
	animation="drift"
	panelFill
>
	<div class="grid h-full min-w-[480px] grid-cols-2 md:min-w-0">
		<!-- chat pane -->
		<div
			class="flex flex-col overflow-hidden border-r border-[rgba(26,24,21,0.06)] p-[18px]"
		>
			<div class="mb-3 text-[14px] font-medium">Plan launch campaign</div>
			<div
				class="mb-[14px] rounded-[10px] border border-[rgba(26,24,21,0.08)] bg-white px-[13px] py-[11px] text-[13.5px] leading-[1.45] text-[#3A3833]"
			>
				plan a launch campaign across all our social channels
			</div>
			<div class="mb-[14px] flex flex-col gap-[9px] text-[13px]">
				<div class="text-[#6E6A62]">
					Thought <span class="text-[#9A968C]">4s</span>
				</div>
				<div class="text-[#6E6A62]">
					Read <span
						class="[font-family:var(--font-mono-landing)] text-[#9A968C]"
						>brand-kit.md</span
					>
				</div>
				<div class="text-[#6E6A62]">
					Searched <span class="text-[#9A968C]">best posting times</span
					>
				</div>
			</div>
			<div
				class="mb-[14px] flex items-center gap-[9px] rounded-[9px] border border-[rgba(26,24,21,0.09)] bg-white px-3 py-[9px]"
			>
				<svg
					width="14"
					height="14"
					viewBox="0 0 24 24"
					fill="none"
					stroke="#9A968C"
					stroke-width="1.8"
					><path
						d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
					></path><path d="M14 2v6h6"></path></svg
				>
				<span
					class="[font-family:var(--font-mono-landing)] text-[13px] text-[#3A3833]"
					>campaign.md</span
				>
				<span
					class="ml-auto [font-family:var(--font-mono-landing)] text-[12px] text-[#4E9A5A]"
					>+68</span
				>
			</div>
			<!-- questions card -->
			<div
				class="mt-auto rounded-[11px] border border-[rgba(26,24,21,0.09)] bg-white p-[14px]"
			>
				<div class="mb-[10px] text-[12.5px] text-[#9A968C]">Questions</div>
				<div class="mb-[10px] text-[13.5px] font-medium">
					Which platforms should I prioritize?
				</div>
				<div class="flex flex-col gap-[9px]">
					<div class="flex gap-[10px] text-[13px] text-[#3A3833]">
						<span class="text-[#B6B1A6]">1</span> All 21 platforms
					</div>
					<div class="flex gap-[10px] text-[13px] text-[#3A3833]">
						<span class="text-[#B6B1A6]">2</span> Just the big 5
					</div>
					<div class="flex gap-[10px] text-[13px] text-[#3A3833]">
						<span class="text-[#B6B1A6]">3</span> Let me choose
					</div>
				</div>
				<div class="mt-[14px] flex items-center justify-end gap-3">
					<span class="text-[13px] text-[#9A968C]">Skip</span>
					<span
						class="rounded-[7px] bg-[#BE8038] px-4 py-[7px] text-[13px] font-medium text-white transition-opacity duration-200 hover:opacity-[0.88]"
						>Continue</span
					>
				</div>
			</div>
			<div
				class="mt-3 flex items-center gap-2 rounded-[10px] border border-[rgba(26,24,21,0.09)] bg-white px-[10px] py-2"
			>
				<span
					class="rounded-[6px] bg-[rgba(190,128,56,0.12)] px-[9px] py-1 text-[12px] text-[#BE8038]"
					>⌗ Plan</span
				>
				<span class="text-[12.5px] text-[#9A968C]">Relay 2.5 ▾</span>
				<span
					class="ml-auto flex size-6 items-center justify-center rounded-full bg-[#E7E4DC] text-[12px] text-[#6E6A62]"
					>↑</span
				>
			</div>
		</div>
		<!-- doc pane -->
		<div class="overflow-hidden px-[22px] py-5">
			<h4 class="mb-4 text-[20px] font-bold text-landing-ink">
				Launch Campaign Plan
			</h4>
			<div class="mb-1.5 text-[14px] font-semibold">Audience</div>
			<p class="mb-4 text-[13.5px] leading-[1.5] text-[#6E6A62]">
				Developers and indie builders who manage multiple social accounts
				and want one API.
			</p>
			<div class="mb-1.5 text-[14px] font-semibold">Cadence</div>
			<p class="mb-5 text-[13.5px] leading-[1.5] text-[#6E6A62]">
				Launch thread at 9 AM, Reel at noon, recap post end of week —
				staggered per platform.
			</p>
			<div class="mb-3 text-[13px] text-[#9A968C]">3 Tasks</div>
			<div class="flex flex-col gap-[13px]">
				<div class="flex gap-[11px] text-[13.5px] text-[#3A3833]">
					<span
						class="size-4 shrink-0 rounded-full border-[1.6px] border-[#C7C2B6]"
					></span>Draft launch thread for X + LinkedIn
				</div>
				<div class="flex gap-[11px] text-[13.5px] text-[#3A3833]">
					<span
						class="size-4 shrink-0 rounded-full border-[1.6px] border-[#C7C2B6]"
					></span>Schedule Reel for Instagram + TikTok
				</div>
				<div class="flex gap-[11px] text-[13.5px] text-[#3A3833]">
					<span
						class="size-4 shrink-0 rounded-full border-[1.6px] border-[#C7C2B6]"
					></span>Queue recap for Blog + Newsletter
				</div>
				<div class="flex gap-[11px] text-[13.5px] text-[#B6B1A6]">
					<span
						class="size-4 shrink-0 rounded-full border-[1.6px] border-[#DAD5C9]"
					></span>Add a task, ⌘K to generate…
				</div>
			</div>
		</div>
	</div>
</Feature>
