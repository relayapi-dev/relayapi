---
import Feature from "./Feature.astro";
import { LANDING_LINKS, scheduleRows } from "./data";
---

<!-- FEATURE 2 — scheduling, caption right, dark window unfolds in from the left -->
<Feature
	title="Works autonomously, runs in parallel"
	description="Relay publishes, retries, and reports back — delivering to every platform at the right time across time zones."
	linkText="Learn about scheduling"
	linkHref={LANDING_LINKS.docs}
	side="right"
	captionAlign="top"
	panelTheme="dark"
	windowTitle="Campaign · Q2 Launch"
	animation="unfold"
	height="clamp(520px,46vw,680px)"
	panelWidth="min(820px,60%)"
>
	<div class="flex flex-col gap-[10px] p-[22px]">
		{
			scheduleRows.map((r) => (
				<div class="flex items-center justify-between rounded-[10px] border border-white/[0.07] bg-white/[0.04] px-[15px] py-[13px]">
					<span class="flex items-center gap-3 text-[14px] text-[#ECE8DF]">
						<span class="flex size-[26px] items-center justify-center rounded-[7px] bg-white/[0.07]">
							<svg width="15" height="15" viewBox="0 0 24 24">
								<path fill="#D7D2C7" d={r.path} />
							</svg>
						</span>
						{r.name}
					</span>
					<span
						class="flex items-center gap-1.5 text-[12.5px] [font-family:var(--font-mono-landing)]"
						style={`color:${r.color}`}
					>
						<span
							class="size-1.5 rounded-full"
							style={`background:${r.color}`}
						/>
						{r.status}
					</span>
				</div>
			))
		}
	</div>
</Feature>
