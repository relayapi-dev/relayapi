---
import { compareRows, LANDING_LINKS } from "./data";
import Container from "./Container.astro";
---

<!-- ================= PRICING ================= -->
<Container as="section" id="pricing" class="py-9">
  <div
    data-reveal
    class="grid grid-cols-2 items-center gap-12 rounded-[1.875rem] bg-[#e9e7df] p-[clamp(32px,4.5vw,64px)]"
  >
    <div>
      <h2 class="mb-3.5 text-[clamp(28px,3vw,44px)] font-medium tracking-[-0.03em] text-landing-ink">Priced to scale, not to gouge.</h2>
      <p class="mb-[26px] max-w-[46ch] text-[17px] leading-[1.5] text-[#6e6a62]">Start free with 200 requests/month. Pro is $5/mo with 10,000 included — then $1 per 1,000 extra. Analytics and comments always included.</p>
      <div class="flex gap-3">
        <a href={LANDING_LINKS.signup} class="rounded-full bg-landing-ink px-6 py-3 text-[15px] font-medium text-[#f3f1ea]!">Start free</a>
        <a href={LANDING_LINKS.pricing} class="rounded-full bg-[#e4e1d9] px-[22px] py-3 text-[15px] font-medium text-landing-ink!">Compare plans</a>
      </div>
    </div>
    <div class="overflow-hidden rounded-[1.125rem] border border-landing-ink/[0.08] bg-[#fbfaf6]">
      <table class="w-full border-collapse text-[14px]">
        <thead>
          <tr class="bg-[#f1efe8]">
            <th class="px-[18px] py-[13px] text-left font-medium text-[#6e6a62]">Platform</th>
            <th class="px-[18px] py-[13px] text-right font-medium text-[#6e6a62]">50 cust.</th>
            <th class="px-[18px] py-[13px] text-right font-medium text-[#6e6a62]">500 cust.</th>
          </tr>
        </thead>
        <tbody>
          {compareRows.map((r) => (
            <tr class="border-t border-landing-ink/[0.07]" style={`--row-color:${r.color}`}>
              <td class="px-[18px] py-3.5 font-medium text-[var(--row-color)]">{r.name}</td>
              <td class="px-[18px] py-3.5 text-right [font-family:var(--font-mono-landing)] text-[var(--row-color)]">{r.c50}</td>
              <td class="px-[18px] py-3.5 text-right [font-family:var(--font-mono-landing)] text-[var(--row-color)]">{r.c500}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Container>
