---
import { Font } from "astro:assets";
import "../styles/globals.css";
---

<html lang="en" class="dash-theme">
	<head>
		<meta charset="utf-8" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1, viewport-fit=cover"
		/>
		<title>Dashboard - RelayAPI</title>
		<meta name="description" content="RelayAPI Dashboard" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="preconnect" href="https://api.relayapi.dev" crossorigin />
		<Font cssVariable="--font-geist-sans" preload />
		<Font cssVariable="--font-geist-mono" preload />
		<script is:inline>
			// Apply saved dashboard theme before paint (light default) to avoid FOUC.
			try {
				if (localStorage.getItem("relay_theme") === "dark") {
					document.documentElement.classList.add("dark");
				}
			} catch (e) {}
		</script>
	</head>
	<body class="antialiased font-sans overflow-hidden">
		<script>
			// Recover from stale chunk hashes (e.g. after a deploy) by reloading —
			// UNLESS a navigation is already tearing the page down. A tap on a nav
			// link starts a native document unload AND (via hover/focus prefetch on
			// iOS's synthesized mouseenter) a dynamic import() that may reject and
			// fire vite:preloadError; reloading then would clobber the in-flight
			// navigation and show up as "tap just refreshes the page" on iOS.
			let navigatingAway = false;
			const markNavigating = () => {
				navigatingAway = true;
			};
			window.addEventListener("pagehide", markNavigating);
			window.addEventListener("beforeunload", markNavigating);
			window.addEventListener("vite:preloadError", () => {
				if (navigatingAway) return;
				// A speculative hover/tap prefetch that failed must not reload — only a
				// genuine page-load chunk error should. dashboard-prefetch.ts raises
				// this counter around its import() calls; reloading on a failed prefetch
				// is the "first tap to an unopened page just refreshes" bug on iOS.
				const w = window as unknown as { __relayPrefetchInFlight?: number };
				if (w.__relayPrefetchInFlight) return;
				window.location.reload();
			});
		</script>
		<slot />
	</body>
</html>
