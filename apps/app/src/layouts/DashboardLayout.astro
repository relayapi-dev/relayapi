---
import "../styles/globals.css";
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Dashboard - RelayAPI</title>
    <meta name="description" content="RelayAPI Dashboard" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <style>
      :root {
        --font-geist-sans: 'Geist Variable', system-ui, sans-serif;
        --font-geist-mono: 'Geist Mono Variable', ui-monospace, monospace;
      }
    </style>
  </head>
  <body class="antialiased font-sans overflow-hidden">
    <script>
      window.addEventListener("vite:preloadError", () => {
        window.location.reload();
      });
    </script>
    <slot />
  </body>
</html>
