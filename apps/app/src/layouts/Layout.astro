---
import "../styles/globals.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <style>
      :root {
        --font-geist-sans: 'Geist Variable', 'Geist Fallback', system-ui, sans-serif;
        --font-geist-mono: 'Geist Mono Variable', 'Geist Mono Fallback', ui-monospace, monospace;
      }
    </style>
    <slot name="head" />
  </head>
  <body class="antialiased font-sans px-4 lg:px-0 overflow-x-hidden">
    <script>
      window.addEventListener("vite:preloadError", () => {
        window.location.reload();
      });
    </script>
    <slot />
  </body>
</html>
