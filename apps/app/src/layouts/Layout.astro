---
import LandingFooter from "../components/landing/LandingFooter.astro";
import LandingNav from "../components/landing/LandingNav.astro";
import SEO from "../components/SEO.astro";
import BaseLayout from "./BaseLayout.astro";

interface Props {
	title?: string;
	description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout>
	<Fragment slot="head">
		<SEO title={title} description={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&display=swap"
		/>
		{/* Page-specific head content (e.g. hero image preloads). */}
		<slot name="head" />
	</Fragment>

	<div class="relay-landing">
		<LandingNav />
		<slot />
		<LandingFooter />
	</div>
</BaseLayout>

<style is:global>
	/* Landing-only overrides — applied wherever Layout is used. */
	html {
		scroll-behavior: smooth;
	}
	body {
		background: #f4f2ec;
		padding-left: 0;
		padding-right: 0;
	}
	.relay-landing {
		min-height: 100vh;
		overflow-x: hidden;
		color: #1a1815;
		font-family:
			"Geist Variable",
			"Geist Fallback",
			-apple-system,
			system-ui,
			sans-serif;
		--font-newsreader: "Newsreader", Georgia, "Times New Roman", serif;
		--font-mono-landing:
			"Geist Mono Variable", "Geist Mono Fallback", ui-monospace,
			monospace;
	}
	.relay-landing ::selection {
		background: #1a1815;
		color: #f3f1ea;
	}
	.relay-landing a {
		color: inherit;
		text-decoration: none;
	}
	/* Scroll-reveal — only armed once JS adds `reveal-ready`, so content is
     never hidden when JS is unavailable. */
	.relay-landing.reveal-ready [data-reveal] {
		opacity: 0;
		transform: translateY(24px);
		transition:
			opacity 0.8s cubic-bezier(0.32, 0.72, 0, 1),
			transform 0.8s cubic-bezier(0.32, 0.72, 0, 1);
	}
	.relay-landing.reveal-ready [data-reveal].is-visible {
		opacity: 1;
		transform: none;
	}
	@media (prefers-reduced-motion: reduce) {
		.relay-landing.reveal-ready [data-reveal] {
			opacity: 1;
			transform: none;
			transition: none;
		}
	}
</style>

<script>
	const root = document.querySelector<HTMLElement>(".relay-landing");
	const els = root
		? Array.from(root.querySelectorAll<HTMLElement>("[data-reveal]"))
		: [];
	const reduceMotion = window.matchMedia(
		"(prefers-reduced-motion: reduce)",
	).matches;

	if (
		root &&
		els.length &&
		"IntersectionObserver" in window &&
		!reduceMotion
	) {
		root.classList.add("reveal-ready");
		const io = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						entry.target.classList.add("is-visible");
						io.unobserve(entry.target);
					}
				}
			},
			{ threshold: 0.1, rootMargin: "0px 0px -6% 0px" },
		);
		for (const el of els) io.observe(el);
	}
</script>
