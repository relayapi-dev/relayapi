---
import LandingFooter from "../components/landing/LandingFooter.astro";
import LandingNav from "../components/landing/LandingNav.astro";
import SEO from "../components/SEO.astro";
import BaseLayout from "./BaseLayout.astro";

interface Props {
	title?: string;
	description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout>
	<Fragment slot="head">
		<SEO title={title} description={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&display=swap"
		/>
		{/* Page-specific head content (e.g. hero image preloads). */}
		<slot name="head" />
	</Fragment>

	<div
		class:list={[
			"relay-landing",
			"min-h-screen overflow-x-hidden text-landing-ink",
			"selection:bg-landing-ink selection:text-[#f3f1ea]",
			"[&_a]:text-inherit [&_a]:no-underline",
			'[--font-newsreader:"Newsreader",Georgia,"Times_New_Roman",serif]',
			"[--font-mono-landing:var(--font-geist-mono),ui-monospace,monospace]",
		]}
	>
		<LandingNav />
		<slot />
		<LandingFooter />
	</div>
</BaseLayout>

<style is:global>
	/* Only the two rules that cannot be expressed as Tailwind utilities on the
	   .relay-landing wrapper remain here. */

	/* (a) Must target the root scroll element, not the wrapper. */
	html {
		scroll-behavior: smooth;
	}

	/* (b) Page canvas + full-bleed gutters. Paints the cream page background on
	   the <body> itself (so the iOS/macOS overscroll gutter reads cream, not
	   white) and neutralizes BaseLayout's <body> `px-4 lg:px-0` so the landing is
	   full-bleed (each <Container> owns its own gutters). Targets the parent
	   <body>, which a utility on the wrapper child cannot reach. */
	body:has(.relay-landing) {
		background: #f7f7f2;
		padding-left: 0;
		padding-right: 0;
	}

	/* (c) Scroll-reveal engine — descendant selectors on SLOTTED children of
	   other components, toggled by the page IntersectionObserver script below.
	   Layout cannot attach utilities to those elements, so the rules stay global.
	   Only armed once JS adds `reveal-ready`, so content is never hidden when JS
	   is unavailable. */
	.relay-landing.reveal-ready [data-reveal] {
		opacity: 0;
		transform: translateY(24px);
		transition:
			opacity 0.8s cubic-bezier(0.32, 0.72, 0, 1),
			transform 0.8s cubic-bezier(0.32, 0.72, 0, 1);
	}
	.relay-landing.reveal-ready [data-reveal].is-visible {
		opacity: 1;
		transform: none;
	}
	@media (prefers-reduced-motion: reduce) {
		.relay-landing.reveal-ready [data-reveal] {
			opacity: 1;
			transform: none;
			transition: none;
		}
	}
</style>

<script>
	const root = document.querySelector<HTMLElement>(".relay-landing");
	const els = root
		? Array.from(root.querySelectorAll<HTMLElement>("[data-reveal]"))
		: [];
	const reduceMotion = window.matchMedia(
		"(prefers-reduced-motion: reduce)",
	).matches;

	if (
		root &&
		els.length &&
		"IntersectionObserver" in window &&
		!reduceMotion
	) {
		root.classList.add("reveal-ready");
		const io = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						entry.target.classList.add("is-visible");
						io.unobserve(entry.target);
					}
				}
			},
			{ threshold: 0.1, rootMargin: "0px 0px -6% 0px" },
		);
		for (const el of els) io.observe(el);
	}
</script>
