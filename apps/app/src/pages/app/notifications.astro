---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { NotificationsRouteApp } from "../../components/dashboard/route-apps/notifications-route-app";
import { getDashboardRouteContext } from "../../lib/dashboard-page";

const dashboard = getDashboardRouteContext(Astro.locals, Astro.url);
---

<DashboardLayout>
	<NotificationsRouteApp
		client:load
		currentPage="notifications"
		requiresApiKey={false}
		{...dashboard}
	/>
</DashboardLayout>
