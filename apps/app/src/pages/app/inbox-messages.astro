---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { InboxMessagesRouteApp } from "../../components/dashboard/route-apps/inbox-messages-route-app";
import { getDashboardRouteContext } from "../../lib/dashboard-page";

const dashboard = getDashboardRouteContext(Astro.locals, Astro.url);
---

<DashboardLayout>
	<InboxMessagesRouteApp
		client:load
		currentPage="inbox-messages"
		{...dashboard}
	/>
</DashboardLayout>
