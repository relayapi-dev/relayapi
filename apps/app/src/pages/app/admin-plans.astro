---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { AdminPlansRouteApp } from "../../components/dashboard/route-apps/admin-plans-route-app";
import { getDashboardRouteContext } from "../../lib/dashboard-page";

const dashboard = getDashboardRouteContext(Astro.locals, Astro.url);
---

<DashboardLayout>
	<AdminPlansRouteApp
		client:load
		currentPage="admin-plans"
		adminOnly={true}
		requiresApiKey={false}
		{...dashboard}
	/>
</DashboardLayout>
