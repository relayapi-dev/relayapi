---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { ConnectionsRouteApp } from "../../components/dashboard/route-apps/connections-route-app";
import {
	getConnectionsPageRouteState,
	getDashboardRouteContext,
} from "../../lib/dashboard-page";

const dashboard = getDashboardRouteContext(Astro.locals, Astro.url);
const pageProps = getConnectionsPageRouteState(Astro.url);
---

<DashboardLayout>
	<ConnectionsRouteApp
		client:load
		currentPage="connections"
		pageProps={pageProps}
		{...dashboard}
	/>
</DashboardLayout>
