---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { AdminUsersRouteApp } from "../../components/dashboard/route-apps/admin-users-route-app";
import { getDashboardRouteContext } from "../../lib/dashboard-page";

const dashboard = getDashboardRouteContext(Astro.locals, Astro.url);
---

<DashboardLayout>
	<AdminUsersRouteApp
		client:load
		currentPage="admin-users"
		adminOnly={true}
		requiresApiKey={false}
		{...dashboard}
	/>
</DashboardLayout>
