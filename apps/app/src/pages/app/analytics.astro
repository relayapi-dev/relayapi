---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { AnalyticsRouteApp } from "../../components/dashboard/route-apps/analytics-route-app";
import {
	getAnalyticsPageInitialProps,
	getDashboardRouteContext,
} from "../../lib/dashboard-page";

const dashboard = getDashboardRouteContext(Astro.locals, Astro.url);
const pageProps = await getAnalyticsPageInitialProps(Astro.locals, Astro.url);
---

<DashboardLayout>
	<AnalyticsRouteApp
		client:load
		currentPage="analytics"
		pageProps={pageProps}
		{...dashboard}
	/>
</DashboardLayout>
