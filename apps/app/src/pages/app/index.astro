---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { PostsRouteApp } from "../../components/dashboard/route-apps/posts-route-app";
import {
	getDashboardRouteContext,
	getPostsPageInitialProps,
} from "../../lib/dashboard-page";

const dashboard = getDashboardRouteContext(Astro.locals, Astro.url);
const pageProps = await getPostsPageInitialProps(Astro.locals, Astro.url);
---

<DashboardLayout>
	<PostsRouteApp
		client:load
		currentPage="posts"
		pageProps={pageProps}
		{...dashboard}
	/>
</DashboardLayout>
