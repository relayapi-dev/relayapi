---
import { AdminOrganizationsRouteApp } from "../../components/dashboard/route-apps/admin-organizations-route-app";
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { getDashboardRouteContext } from "../../lib/dashboard-page";

const dashboard = getDashboardRouteContext(Astro.locals, Astro.url);
---

<DashboardLayout>
	<AdminOrganizationsRouteApp
		client:load
		currentPage="admin-organizations"
		adminOnly={true}
		requiresApiKey={false}
		{...dashboard}
	/>
</DashboardLayout>
