---
// TEMP route for mobile-layout verification of the Ads page. Safe to delete.
import DashboardLayout from "../layouts/DashboardLayout.astro";
import { AdsPreview } from "../components/dashboard/pages/__ads_preview";

const tab = (Astro.url.searchParams.get("tab") ?? "ads") as
  | "ads"
  | "campaigns"
  | "audiences"
  | "accounts";
---

<DashboardLayout>
  <main class="mx-auto max-w-7xl overflow-x-clip px-5 pt-4">
    <AdsPreview client:load tab={tab} />
  </main>
</DashboardLayout>
