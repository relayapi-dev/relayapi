---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SEO from "../../components/SEO.astro";
import { PlatformPage } from "../../components/pages/platform-page";
import { ApiPage } from "../../components/pages/api-page";
import { getPlatformBySlug } from "../../lib/platform-data";
import { getApiBySlug } from "../../lib/api-data";

const { slug } = Astro.params;

const platform = slug ? getPlatformBySlug(slug) : undefined;
const api = slug ? getApiBySlug(slug) : undefined;

const data = platform ?? api;
if (!data) {
  return Astro.redirect("/404");
}

const title = platform ? `${platform.name} API` : data.name;
const description = platform ? platform.heroDescription : data.heroDescription;
const pageType = platform ? "platform" : "api";
---

<BaseLayout>
  <SEO
    slot="head"
    title={title}
    description={description}
    keywords={[data.name.toLowerCase(), "api", "social media api", slug!]}
    faqs={data.faq}
  />
  {pageType === "platform" ? (
    <PlatformPage slug={slug!} client:load />
  ) : (
    <ApiPage slug={slug!} client:load />
  )}
</BaseLayout>
