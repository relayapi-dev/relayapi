---
import Layout from "../layouts/Layout.astro";
import SEO from "../components/SEO.astro";
import { Navbar } from "../components/section/navbar";
import { PricingSection } from "../components/section/pricing-section";
import { FAQSection } from "../components/section/faq-section";
import { SelfHostSection } from "../components/section/self-host-section";
import { Button } from "../components/ui/button";
---

<Layout>
  <SEO
    slot="head"
    title="Pricing"
    description="Simple, transparent pricing for RelayAPI. Start free, scale as you grow."
    keywords={["api pricing", "social media api pricing", "relayapi pricing"]}
  />
  <div class="max-w-7xl mx-auto border-x border-border">
    <Navbar client:load />
    <main class="flex flex-col divide-y divide-border pt-16">
      <section class="py-16 md:py-24 px-6 text-center">
        <p class="text-sm font-semibold text-muted-foreground uppercase tracking-wider">
          Pricing
        </p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter text-foreground mt-4 text-balance">
          Simple, transparent pricing
        </h1>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto mt-6 text-balance">
          Start free with 200 requests/month. Upgrade to Pro for $5/mo.
          No hidden fees, no per-platform charges.
        </p>
      </section>

      <PricingSection client:load />
      <FAQSection client:visible />
      <SelfHostSection />

      <section class="py-8">
        <div class="px-6 md:px-12 pb-8">
          <div class="bg-primary rounded-2xl p-8 md:p-12 flex flex-col items-center text-center space-y-6">
            <h2 class="text-3xl md:text-4xl font-medium tracking-tighter text-white text-balance">
              Ready to get started?
            </h2>
            <p class="text-white/80 text-lg font-medium">
              Free plan available. No credit card required.
            </p>
            <Button
              asChild
              size="lg"
              variant="outline"
              className="border-white text-white hover:bg-white/10 rounded-full px-8"
            >
              <a href="/signup">Start Free Trial</a>
            </Button>
          </div>
        </div>

        <div class="border-t border-border py-4">
          <p class="text-sm text-muted-foreground text-center">
            &copy; {new Date().getFullYear()} Relay. All rights reserved.
          </p>
        </div>
      </section>
    </main>
  </div>
</Layout>
