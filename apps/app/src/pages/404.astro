---
import Container from "../components/landing/Container.astro";
import Layout from "../layouts/Layout.astro";
import "../styles/globals.css";

const isApp = Astro.url.pathname.startsWith("/app");
---

{
	isApp ? (
		<html lang="en" class="dark">
			<head>
				<meta charset="utf-8" />
				<meta
					name="viewport"
					content="width=device-width, initial-scale=1, viewport-fit=cover"
				/>
				<title>Page Not Found – Dashboard</title>
				<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
				<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
				<link rel="preconnect" href="https://fonts.googleapis.com" />
				<link
					rel="preconnect"
					href="https://fonts.gstatic.com"
					crossorigin
				/>
				<link
					href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap"
					rel="stylesheet"
				/>
				<style>
					{`:root {
						--font-geist-sans: 'Geist', system-ui, sans-serif;
						--font-geist-mono: 'Geist Mono', ui-monospace, monospace;
					}`}
				</style>
			</head>
			<body class="antialiased font-sans bg-background text-foreground">
				<div class="flex min-h-screen items-center justify-center">
					<div class="text-center max-w-sm px-6">
						<p class="text-7xl font-bold tracking-tighter text-muted-foreground">
							404
						</p>
						<h1 class="mt-4 text-xl font-semibold">Page not found</h1>
						<p class="mt-2 text-sm text-muted-foreground">
							The page you're looking for doesn't exist or has been moved.
						</p>
						<a
							href="/app/posts"
							class="mt-6 inline-flex items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors"
						>
							Go to Dashboard
						</a>
					</div>
				</div>
			</body>
		</html>
	) : (
		<Layout title="Page not found">
			<Container
				as="section"
				class="flex min-h-[70vh] flex-col items-center justify-center py-[clamp(4rem,10vw,8rem)] text-center"
			>
				<p class="text-[clamp(88px,16vw,176px)] font-medium leading-none tracking-[-0.05em] text-landing-ink/15">
					404
				</p>
				<h1 class="mt-2 text-[clamp(26px,3.5vw,40px)] font-medium tracking-[-0.03em] text-landing-ink">
					This page took a wrong turn.
				</h1>
				<p class="mx-auto mt-4 max-w-[44ch] text-[16px] leading-[1.55] text-[#6e6a62]">
					The page you're looking for doesn't exist or has moved. Let's get you
					back on track.
				</p>
				<div class="mt-8 flex flex-wrap justify-center gap-[10px]">
					<a
						href="/"
						class="rounded-full bg-landing-ink px-[22px] py-3 text-[15px] font-medium text-[#f3f1ea]! transition-opacity duration-150 hover:opacity-[0.88]"
					>
						Back home
					</a>
					<a
						href="/pricing"
						class="rounded-full bg-[#e4e1d9] px-[22px] py-3 text-[15px] font-medium text-landing-ink! transition-colors duration-150 hover:bg-[#dbd7cc]"
					>
						See pricing
					</a>
				</div>
			</Container>
		</Layout>
	)
}
