>
	<link slot="head" rel="preload" as="image" href="/hero.png" />

	<LandingHero />
	<HeroProductBand />
	<TrustStrip />
	<FeatureChat />
	<FeatureSchedule />
	<TestimonialWall />
	<FrontierTrio />
	<PricingBand />
	<ChangelogList />
	<OpenSource />
	<BlogHighlights />
	<FinalCTA />
</LandingLayout>
